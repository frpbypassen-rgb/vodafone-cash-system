        </a>
        <a href="/broadcast" class="<%= typeof activePage !== 'undefined' && activePage === 'broadcast' ? 'active' : '' %>">
            <i class="fa-solid fa-bullhorn"></i> الإشعارات والبث
        </a>

        <a href="/settings" class="<%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
            <i class="fa-solid fa-gear"></i> إعدادات المنظومة
        </a>
        
        <div class="mt-4 pt-3 border-top px-2" style="border-color: rgba(255,255,255,0.1) !important;">
            <a href="javascript:void(0)" onclick="toggleGlobalTheme()" style="background: rgba(212, 175, 55, 0.1); border: 1px dashed #d4af37; color: #d4af37;">
                <i id="sidebarThemeIcon" class="fa-solid fa-moon"></i> <span id="sidebarThemeText">التبديل للوضع الليلي</span>
            </a>
            <a href="/logout" class="fw-bold mt-2" style="color: #ff6b6b; background: rgba(220,53,69,0.05); border: 1px dashed rgba(220,53,69,0.3);">
                <i class="fa-solid fa-power-off me-2"></i> تسجيل الخروج
            </a>
        </div>
    </div>
</div>

<script>
    function setAdminSidebarState(forceOpen) {
        const sidebar = document.getElementById('sidebarMenu');
        const overlays = document.querySelectorAll('.sidebar-overlay');
        const primaryOverlay = document.getElementById('sidebarOverlay') || overlays[0];
        if(sidebar) {
            const shouldOpen = typeof forceOpen === 'boolean' ? forceOpen : !sidebar.classList.contains('active');
            sidebar.classList.toggle('active', shouldOpen);
            overlays.forEach(overlay => overlay.classList.toggle('active', shouldOpen && overlay === primaryOverlay));
            document.body.classList.toggle('sidebar-open', shouldOpen);
        }
    }

    function toggleSidebar() {
        setAdminSidebarState();
    }

    function toggleGlobalTheme() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('ahram_theme', newTheme);
        updateSidebarThemeIcon(newTheme);

        if (typeof Chart !== 'undefined' && window.myChart) {
            const color = newTheme === 'dark' ? '#94a3b8' : '#6c757d';
            Chart.defaults.color = color;
            if(window.myChart.options.scales.x) window.myChart.options.scales.x.ticks.color = color;
            if(window.myChart.options.scales.y) window.myChart.options.scales.y.ticks.color = color;
            window.myChart.update();
        }
    }

    function updateSidebarThemeIcon(theme) {
        const icon = document.getElementById('sidebarThemeIcon');
        const mobileIcon = document.getElementById('mobileThemeIcon');
        const text = document.getElementById('sidebarThemeText');
        if (icon && text) {
            icon.className = theme === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
            text.innerText = theme === 'dark' ? ' التبديل للوضع النهاري' : ' التبديل للوضع الليلي';
        }
        if (mobileIcon) {
            mobileIcon.className = theme === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('ahram_theme') || 'light';
        updateSidebarThemeIcon(savedTheme);
        document.querySelectorAll('.sidebar-menu a[href]:not([href^="javascript"])').forEach(link => {
            link.addEventListener('click', () => {
                if (window.matchMedia('(max-width: 991px)').matches) setAdminSidebarState(false);
            });
        });
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') setAdminSidebarState(false);
        });
        window.addEventListener('resize', () => {
            if (!window.matchMedia('(max-width: 991px)').matches) setAdminSidebarState(false);
        });
    });
</script>
