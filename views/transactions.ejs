<script src="/vendor/bootstrap/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }

    const botsMapElement = document.getElementById('botsMapData');
    const allBotsMap = botsMapElement && botsMapElement.textContent.trim() ? JSON.parse(botsMapElement.textContent) : {};

    // 🟢 دالة عرض نافذة السجل المنبثقة (مُحدثة لتقرأ الجملة الجديدة والقديمة معاً)
    function showApiLog(btn) {
        const rawNotes = decodeURIComponent(btn.getAttribute('data-log'));
        let logContent = rawNotes;
        
        // التحقق من الصيغة القديمة والصيغة الجديدة
        if (rawNotes.includes('--- سجل الـ API (Terminal Log) ---')) {
            logContent = rawNotes.split('--- سجل الـ API (Terminal Log) ---')[1].trim();
        } else if (rawNotes.includes('--- سجل الـ API ---')) {
            logContent = rawNotes.split('--- سجل الـ API ---')[1].trim();
        } else if (rawNotes.includes('--- سجل الـ API')) {
            logContent = rawNotes.split('--- سجل الـ API')[1].trim();
        }
        
        Swal.fire({
            title: '<div style="color:#10b981; font-family:monospace; font-size:1.2rem; display:flex; align-items:center; gap:10px; justify-content:center;"><i class="fa-solid fa-terminal"></i> سجل التخاطب مع السيرفر</div>',
            html: `<div style="background:#0f172a; color:#a5b4fc; padding:15px; border-radius:8px; text-align:left; direction:ltr; font-family:'JetBrains Mono', monospace; font-size:0.85rem; white-space:pre-wrap; max-height:400px; overflow-y:auto; border:1px solid #334155; box-shadow:inset 0 2px 4px rgba(0,0,0,0.5);">${logContent}</div>`,
            background: '#1e293b',
            color: '#fff',
            confirmButtonColor: '#3b82f6',
            confirmButtonText: 'إغلاق الشاشة',
            width: '600px',
            customClass: { popup: 'border border-secondary rounded-4' }
        });
    }

    function openEditTxModal(txId, currentAmount, currentIsoDate) {
        document.getElementById('editTxForm').action = '/transaction/' + txId + '/edit-data';
        document.getElementById('newAmountInput').value = currentAmount;
        if (currentIsoDate) {
            const dateObj = new Date(currentIsoDate);
            const tzOffset = dateObj.getTimezoneOffset() * 60000; 
            document.getElementById('newDateInput').value = (new Date(dateObj - tzOffset)).toISOString().slice(0, 16);
        }
        new bootstrap.Modal(document.getElementById('editTxModal')).show();
    }

    function openEditRateModal(txId, currentRate) {
        document.getElementById('editRateForm').action = '/transaction/' + txId + '/edit-rate';
        document.getElementById('newRateInput').value = (currentRate && currentRate !== '0') ? currentRate : '';
        new bootstrap.Modal(document.getElementById('editRateModal')).show();
    }

    function handleProofThumbError(img) {
        img.style.display = 'none';
        const fallback = img.parentElement ? img.parentElement.querySelector('.proof-thumb-fallback') : null;
        if (fallback) fallback.style.display = 'flex';
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.innerText = value || '---';
    }

    function setHtml(id, value) {
        const el = document.getElementById(id);
        if (el) el.innerHTML = value || '';
    }

    function escapeHtmlValue(value) {
        return String(value === undefined || value === null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function amountText(value, currency) {
        const numeric = Number(value || 0);
        return `${numeric.toFixed(2)} ${currency}`;
    }

    function getStatusBadge(status) {
        const badges = {
            completed: '<span class="badge-st st-done"><i class="fa-solid fa-circle-check"></i> مكتمل</span>',
            pending: '<span class="badge-st st-wait"><i class="fa-solid fa-circle-pause"></i> معلق</span>',
            processing: '<span class="badge-st st-proc"><i class="fa-solid fa-spinner fa-spin"></i> توجيه</span>',
            accepted: '<span class="badge-st st-work"><i class="fa-solid fa-user-check"></i> قيد العمل</span>',
            deposit_pending: '<span class="badge-st st-wait"><i class="fa-solid fa-hand-holding-dollar"></i> طلب إيداع</span>',
            deposit: '<span class="badge-st st-done"><i class="fa-solid fa-arrow-down"></i> إيداع</span>',
            deduction: '<span class="badge-st st-fail"><i class="fa-solid fa-arrow-up"></i> خصم</span>',
            rejected: '<span class="badge-st st-fail"><i class="fa-solid fa-ban"></i> ملغي</span>'
        };
        return badges[status] || `<span class="badge-st st-fail"><i class="fa-solid fa-circle-exclamation"></i> ${escapeHtmlValue(status || 'غير محدد')}</span>`;
    }

    function getTypeBadge(tx) {
        if (tx.transferType === 'post_account') return '<span class="badge-st st-wait"><i class="fa-solid fa-envelope"></i> حساب بريد</span>';
        if (tx.transferType === 'post_card') return '<span class="badge-st st-proc"><i class="fa-solid fa-id-card"></i> بطاقة عميل</span>';
        if (tx.status === 'deposit' || tx.status === 'deduction') return '<span class="badge-st" style="background: rgba(100,116,139,0.1); color:#64748b;"><i class="fa-solid fa-money-bill-wave"></i> تسوية مالية</span>';
        return '<span class="badge-st st-fail"><i class="fa-solid fa-mobile-screen"></i> فودافون كاش</span>';
    }

    function cleanTransactionNote(notes) {
        let displayNote = notes || 'لا توجد ملاحظات إضافية.';
        if (displayNote.includes('--- سجل الـ API')) {
            displayNote = displayNote.split('--- سجل الـ API')[0].trim();
        }
        return displayNote || 'لا توجد ملاحظات إضافية.';
    }

    function setStage(id, state) {
        const el = document.getElementById(id);
        if (!el) return;
        el.className = `tx-stage-item${state ? ` is-${state}` : ''}`;
    }

    function getProofList(tx) {
        if (Array.isArray(tx.proofImages) && tx.proofImages.length > 0) return tx.proofImages.filter(Boolean);
        if (tx.proofImage && String(tx.proofImage).trim() !== '') return [tx.proofImage];
        return [];
    }

    function viewTransactionDetails(el) {
        const tx = JSON.parse(el.getAttribute('data-tx'));
        window.currentTxToPrint = tx;

        const f = (d) => d ? new Date(d).toLocaleString('en-GB').replace(',', '') : '---';
        const displayId = tx.customId || (tx._id ? String(tx._id).slice(-6) : '---');
        const isCompany = tx.companyName && tx.companyName !== 'عميل فردي';
        const entityName = isCompany ? tx.companyName : (tx.employeeName || 'عميل فردي');
        const requesterName = tx.employeeName || (isCompany ? 'غير محدد' : entityName);
        const botName = tx.executorBotName || (tx.executorBotId ? allBotsMap[tx.executorBotId] : 'غير محدد');
        const rate = tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (Number(tx.amount || 0) / Number(tx.costLYD || 1)).toFixed(2) : '---');
        const statusBadge = getStatusBadge(tx.status);

        setText('m_header_id', `#${displayId}`);
        setHtml('m_header_status', statusBadge);
        setText('m_entity', entityName);
        setText('m_header_entity', isCompany ? `طالب العملية: ${requesterName}` : 'عميل فردي');
        setText('m_header_created', f(tx.createdAt));
        setText('m_requester', requesterName);
        setText('m_bot_name_text', botName);
        setHtml('m_type', getTypeBadge(tx));
        setText('m_phone', tx.vodafoneNumber || tx.accountNumber || '---');
        setText('m_egp', amountText(tx.amount, 'EGP'));
        setText('m_rate', rate);
        setText('m_lyd', tx.costLYD ? amountText(tx.costLYD, 'LYD') : '---');
        setText('m_note', cleanTransactionNote(tx.notes));
        setHtml('m_t_status', statusBadge);

        const accountBox = document.getElementById('m_account_name_box');
        if (tx.accountName && tx.transferType !== 'vodafone') {
            setText('m_account_name', tx.accountName);
            accountBox.style.display = 'block';
        } else {
            accountBox.style.display = 'none';
        }

        const editBtn = document.getElementById('m_bot_edit_btn');
        const editForm = document.getElementById('m_bot_edit_form');
        editForm.style.display = 'none';
        if (tx.status === 'completed' && tx.executorBotId) {
            editBtn.style.display = 'inline-flex';
            document.getElementById('changeBotForm').action = '/transaction/' + tx._id + '/change-bot';
        } else {
            editBtn.style.display = 'none';
        }

        setText('m_t_created', f(tx.createdAt));
        setText('m_t_executor', tx.executorName ? `${botName} / ${tx.executorName}` : botName);
        setText('m_t_accepted', ['accepted', 'completed', 'deposit', 'deduction'].includes(tx.status) ? f(tx.updatedAt) : 'في انتظار القبول');
        setText('m_t_completed', ['completed', 'deposit', 'deduction'].includes(tx.status) ? f(tx.updatedAt) : (tx.status === 'rejected' ? 'تم إيقاف العملية' : 'لم تكتمل بعد'));

        setStage('m_stage_created', 'done');
        setStage('m_stage_routed', tx.executorBotId || ['processing', 'accepted', 'completed'].includes(tx.status) ? (tx.status === 'processing' ? 'active' : 'done') : '');
        setStage('m_stage_accepted', tx.status === 'accepted' ? 'active' : (['completed', 'deposit', 'deduction'].includes(tx.status) ? 'done' : ''));
        setStage('m_stage_completed', tx.status === 'rejected' ? 'failed' : (['completed', 'deposit', 'deduction'].includes(tx.status) ? 'done' : ''));

        const proofs = getProofList(tx);
        setText('m_proof_count', proofs.length ? `${proofs.length} صورة` : 'لا يوجد');
        const container = document.getElementById('m_proof_container');
        if (container) {
            if (proofs.length === 1) {
                container.innerHTML = `<img src="/proxy/image/${tx._id}/0" alt="إثبات العملية ${escapeHtmlValue(displayId)}">`;
            } else if (proofs.length > 1) {
                let indicators = '';
                let items = '';
                proofs.forEach((proof, index) => {
                    indicators += `<button type="button" data-bs-target="#proofCarousel" data-bs-slide-to="${index}" class="${index === 0 ? 'active' : ''}" aria-label="صورة ${index + 1}"></button>`;
                    items += `<div class="carousel-item ${index === 0 ? 'active' : ''}"><img src="/proxy/image/${tx._id}/${index}" class="d-block mx-auto" alt="إثبات العملية ${escapeHtmlValue(displayId)} - ${index + 1}"></div>`;
                });
                container.innerHTML = `
                    <div id="proofCarousel" class="carousel slide w-100" data-bs-ride="carousel">
                        <div class="carousel-indicators">${indicators}</div>
                        <div class="carousel-inner">${items}</div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#proofCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon" aria-hidden="true"></span></button>
                        <button class="carousel-control-next" type="button" data-bs-target="#proofCarousel" data-bs-slide="next"><span class="carousel-control-next-icon" aria-hidden="true"></span></button>
                    </div>`;
            } else {
                container.innerHTML = '<div class="text-muted text-center"><i class="fa-solid fa-image fs-1 d-block mb-2 opacity-25"></i> لم يتم إرفاق إثبات تنفيذ بعد</div>';
            }
        }

        new bootstrap.Modal(document.getElementById('txModal')).show();
    }

    function printInvoice() {
        if (!window.currentTxToPrint) return;
        const tx = window.currentTxToPrint;
        const f = (d) => d ? new Date(d).toLocaleString('ar-EG', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : '---';
        const entityName = (tx.companyName && tx.companyName !== 'عميل فردي') ? tx.companyName : (tx.employeeName || 'عميل فردي');
        let typeLabel = 'محفظة كاش'; 
        let numStrP = tx.vodafoneNumber || tx.accountNumber || '';
        if(tx.transferType === 'post_account') typeLabel = 'حساب بريد';
        else if(tx.transferType === 'post_card') typeLabel = 'بطاقة عميل'; 
        else if(tx.status === 'deposit' || tx.status === 'deduction') typeLabel = 'تسوية مالية';
        else if(numStrP.startsWith('010')) typeLabel = 'فودافون كاش';
        else if(numStrP.startsWith('011')) typeLabel = 'اتصالات كاش';
        else if(numStrP.startsWith('012')) typeLabel = 'اورانج كاش';
        else if(numStrP.startsWith('015')) typeLabel = 'وي باي';

        const statusMap = { 'completed': 'مكتمل ✅', 'pending': 'معلق ⏳', 'processing': 'قيد التوجيه ⚙️', 'accepted': 'قيد العمل 👤', 'deposit': 'إيداع 💰', 'deduction': 'خصم 📉', 'rejected': 'ملغي ❌', 'deposit_pending': 'طلب إيداع 🖐️' };
        const statusText = statusMap[tx.status] || tx.status;
        const rate = tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (tx.amount / tx.costLYD).toFixed(2) : '---');
        const costLYD = tx.costLYD ? tx.costLYD.toFixed(2) : '---';
        const accountNameHtml = tx.accountName ? `<tr><th>اسم المستلم:</th><td>${tx.accountName}</td></tr>` : '';
        const printWindow = window.open('', '_blank');
        printWindow.document.write(`
            <html lang="ar" dir="rtl"><head><title>فاتورة ${tx.customId || tx._id}</title><link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;800&display=swap" rel="stylesheet"><style> * { box-sizing: border-box; } @page { size: A4; margin: 10mm; } body { font-family: 'Tajawal', sans-serif; background: #fff; color: #333; margin: 0; padding: 0; font-size: 14px; -webkit-print-color-adjust: exact; print-color-adjust: exact; } .invoice-box { width: 100%; padding: 10px; border-top: 10px solid #001a4d; } .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #eee; padding-bottom: 10px; margin-bottom: 15px; } .header .logo-text { color: #001a4d; font-size: 26px; font-weight: 800; margin: 0 0 5px 0; } 
            .header .sub-text { color: #dc3545; font-size: 13px; font-weight: 700; margin: 0; } .invoice-info table { width: 100%; font-size: 13px; text-align: left;} .invoice-info td { padding: 4px 8px; font-weight: 700; color: #444; } .invoice-info .highlight { color: #001a4d; background: #f8f9fa; border-radius: 4px; } .title-bar { background-color: #f8f9fa; padding: 6px 15px; border-right: 5px solid #d4af37; font-size: 15px; font-weight: 800; color: #001a4d; margin-bottom: 15px; page-break-after: avoid; } .content-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 14px; page-break-inside: avoid; } .content-table th, .content-table td { border: 1px solid #ddd; padding: 8px 15px; text-align: right; } .content-table th { background-color: #f8f9fa; color: #001a4d; font-weight: 800; width: 30%; } .content-table td { font-weight: 700; color: #222; } .totals-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; page-break-inside: avoid; } .qr-placeholder { width: 90px; height: 90px; border: 2px dashed #ccc; display: flex; align-items: center; justify-content: center; color: #aaa; font-weight: bold; border-radius: 8px; font-size: 12px; text-align: center; } .totals { width: 75%; border-collapse: collapse; } .totals th, .totals td { border: 2px solid #001a4d; padding: 8px; text-align: center; } .totals th { background-color: #001a4d; color: #fff; font-weight: 800; font-size: 14px; } .totals td { font-weight: 800; font-size: 17px; background: #fafafa; } .totals .lyd { color: #dc3545; } .totals .egp { color: #198754; } .footer { text-align: center; color: #666; border-top: 1px dashed #ccc; padding-top: 15px; font-size: 12px; font-weight: 700; margin-top: 20px; page-break-inside: avoid; }</style></head>
            <body><div class="invoice-box"><div class="header"><div><h1 class="logo-text">شركة الأهرام</h1><p class="sub-text">لخدمات التحويلات المالية الذكية</p></div><div class="invoice-info"><table><tr><td>رقم الفاتورة:</td><td class="highlight" dir="ltr">#${tx.customId || tx._id.slice(-6)}</td></tr><tr><td>تاريخ الإصدار:</td><td class="highlight" dir="ltr">${f(tx.createdAt)}</td></tr><tr><td>حالة العملية:</td><td class="highlight" style="color:#198754;">${statusText}</td></tr></table></div></div><div class="title-bar">تفاصيل الجهة والمستفيد</div><table class="content-table"><tr><th>الجهة / العميل:</th><td>${entityName}</td></tr><tr><th>رقم الهاتف / الحساب:</th><td dir="ltr" style="text-align: right; letter-spacing: 1px;">${tx.vodafoneNumber || tx.accountNumber || '---'}</td></tr>${accountNameHtml}<tr><th>نوع التحويل:</th><td>${typeLabel}</td></tr><tr><th>الموظف المنفذ:</th><td>${tx.executorName || '---'}</td></tr><tr><th>ملاحظات إضافية:</th><td style="color:#666; font-size: 13px;">${tx.notes || 'لا توجد ملاحظات.'}</td></tr></table><div class="title-bar">تفاصيل المبالغ والتكلفة</div><div class="totals-container"><div class="qr-placeholder">QR Code<br>للتوثيق</div><table class="totals"><tr><th>سعر الصرف المعتمد</th><th>المبلغ المحول (مصري)</th><th>التكلفة (ليبي)</th></tr><tr><td>${rate}</td><td class="egp">${tx.amount.toFixed(2)} EGP</td><td class="lyd">${costLYD} LYD</td></tr></table></div><div class="footer">نقدر ثقتكم في خدماتنا.. شكراً لاختياركم شركة الأهرام 🚀<br><span style="font-weight: 400; color:#999; margin-top:5px; display:inline-block;">هذه الفاتورة تم إصدارها إلكترونياً ولا تحتاج إلى ختم أو توقيع.</span></div></div><script>window.onload = function() { setTimeout(function() { window.print(); window.close(); }, 500); }<\/script></body></html>
        `);
        printWindow.document.close();
    }

    function printReport() {
        const fromD = document.getElementById('fromDateInput').value || '';
        const toD = document.getElementById('toDateInput').value || ''; 
        const status = document.getElementById('statusFilter').value || ''; 
        const search = document.getElementById('searchInput').value || '';
        window.open(`/transactions/print?` + new URLSearchParams({ fromDate: fromD, toDate: toD, status: status, search: search }).toString(), '_blank');
    }

    function confirmEmergencyAlert(form) {
        const msg = prompt("🚨 رسالة الإنذار للمنفذ:", "تنبيه عاجل! يرجى التنفيذ فوراً!");
        if (msg === null) return false; 
        form.querySelector('.alert-message-input').value = msg; 
        return true;
    }

    function promptRejectDeposit(form) {
        const reason = prompt("❌ سبب رفض طلب الإيداع:");
        if (!reason) return false; 
        form.querySelector('.reject-reason-input').value = reason; 
        return true;
    }

    let currentDepTxId = null;
    function showAcceptDepositModal(id) { 
        currentDepTxId = id; 
        document.getElementById('depositProofInput').value = ''; 
        new bootstrap.Modal(document.getElementById('acceptDepositModal')).show();
    }

    document.getElementById('btnFinishDepositAccept').onclick = async function() {
        const file = document.getElementById('depositProofInput').files[0];
        if(!file) return Swal.fire('خطأ','يرجى اختيار الإيصال','error');
        const btn = this; 
        btn.disabled = true; 
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> جاري الرفع...';
        const reader = new FileReader();
        reader.onload = async function() {
            const res = await fetch('/transaction/' + currentDepTxId + '/accept-deposit-web', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ imageBase64: reader.result }) });
            if((await res.json()).success) window.location.reload(); 
            else { 
                Swal.fire('خطأ', 'فشل الرفع', 'error'); 
                btn.disabled = false; 
                btn.innerHTML = 'تأكيد وموافقة';
            }
        }; 
        reader.readAsDataURL(file);
    };

    setInterval(() => {
        const isModalOpen = document.querySelector('.modal.show'); const isDropdownOpen = document.querySelector('.dropdown-menu.show'); 
        if (isModalOpen || isDropdownOpen) return;
        fetch(window.location.href).then(res => res.text()).then(htmlText => {
            const doc = new DOMParser().parseFromString(htmlText, 'text/html');
            const newTbody = doc.querySelector('#transactionsTable tbody');
            const currentTbody = document.querySelector('#transactionsTable tbody');
            if (newTbody && currentTbody) currentTbody.innerHTML = newTbody.innerHTML;
            const newMobileCards = doc.querySelector('#mobileCardsContainer');
            const currentMobileCards = document.querySelector('#mobileCardsContainer');
            if (newMobileCards && currentMobileCards) currentMobileCards.innerHTML = newMobileCards.innerHTML;
            const newPagination = doc.querySelector('.pagination'); const currentPagination = document.querySelector('.pagination'); if (newPagination && currentPagination) currentPagination.innerHTML = newPagination.innerHTML;
        }).catch(()=>{});
    }, 5000);
</script>
</body>
</html>
