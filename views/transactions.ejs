<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>سجل العمليات | الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="/vendor/bootstrap/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700;800&display=swap" rel="stylesheet">
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>

    <style>
        .summary-box { border-radius: 20px; padding: 20px; display: flex; justify-content: space-between; align-items: center; height: 100%; position: relative; overflow: hidden;}
        .summary-box::after { content: ''; position: absolute; right: 0; top: 0; width: 6px; height: 100%; }
        .box-success::after { background: #10b981; } .box-primary::after { background: #3b82f6; } .box-danger::after { background: #ef4444; }
        .summary-val { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 900; line-height: 1;}
        .summary-icon { font-size: 2.5rem; opacity: 0.15; }

        .btn-action-sm { width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 0.9rem; transition: 0.2s; border: 1px solid transparent; background: rgba(0,0,0,0.05); color: var(--text-main); text-decoration: none;}
        [data-theme="dark"] .btn-action-sm { background: rgba(255,255,255,0.05); }
        .btn-action-sm:hover { transform: translateY(-2px); }
        .btn-action-sm.edit:hover { background: var(--brand-gold); color: black; border-color: var(--brand-gold); }
        .btn-action-sm.send:hover { background: #3b82f6; color: white; border-color: #3b82f6; }
        .btn-action-sm.del:hover { background: #ef4444; color: white; border-color: #ef4444; }
        
        /* 🟢 تنسيق زر الـ API الجديد */
        .btn-action-sm.api-log { color: #10b981; background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2);}
        .btn-action-sm.api-log:hover { background: #10b981; color: white; border-color: #10b981; }

        .proof-thumb-btn {
            border: 0;
            background: transparent;
            color: var(--text-main);
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            padding: 0;
            cursor: pointer;
            text-decoration: none;
        }
        .proof-thumb-frame {
            width: 72px;
            height: 56px;
            border-radius: 12px;
            border: 1px solid var(--border-glass);
            background: var(--input-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            box-shadow: var(--shadow-soft);
        }
        .proof-thumb-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .proof-thumb-fallback {
            display: none;
            width: 100%;
            height: 100%;
            align-items: center;
            justify-content: center;
            color: var(--brand-gold);
            font-size: 1.25rem;
        }
        .proof-thumb-count {
            position: absolute;
            bottom: 4px;
            left: 4px;
            min-width: 22px;
            height: 20px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.82);
            color: #fff;
            font-size: 0.72rem;
            font-weight: 900;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
        }
        .proof-thumb-label {
            color: var(--text-muted);
            font-size: 0.72rem;
            font-weight: 900;
        }
        .proof-empty {
            color: var(--text-muted);
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 800;
            opacity: 0.75;
        }
        .proof-mobile-btn {
            width: 100%;
            border: 1px solid var(--border-glass);
            background: var(--input-bg);
            color: var(--text-main);
            border-radius: 14px;
            padding: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-align: right;
            cursor: pointer;
        }
        .proof-mobile-btn .proof-thumb-frame {
            width: 78px;
            height: 62px;
            flex: 0 0 auto;
        }
        .proof-mobile-title {
            display: block;
            font-weight: 900;
            color: var(--text-main);
        }
        .proof-mobile-subtitle {
            display: block;
            margin-top: 4px;
            color: var(--text-muted);
            font-size: 0.78rem;
            font-weight: 800;
        }

        .badge-st { padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 800; display: inline-flex; align-items: center; gap: 6px; border: 1px solid transparent; }
        .st-done { background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);}
        .st-wait { background: rgba(245, 158, 11, 0.1); color: #d97706; border-color: rgba(245, 158, 11, 0.2);} [data-theme="dark"] .st-wait { color: var(--brand-gold);}
        .st-proc { background: rgba(14, 165, 233, 0.1); color: #0ea5e9; border-color: rgba(14, 165, 233, 0.2);}
        .st-work { background: rgba(59, 130, 246, 0.1); color: #3b82f6; border-color: rgba(59, 130, 246, 0.2);}
        .st-dep  { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; border-color: rgba(139, 92, 246, 0.2);}
        .st-fail { background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: rgba(239, 68, 68, 0.2);}

        .clickable-id { font-family: 'JetBrains Mono', monospace; font-weight: 900; color: var(--brand-primary); text-decoration: none; border-bottom: 2px dashed rgba(0,0,0,0.2); cursor: pointer; transition: 0.2s;}
        [data-theme="dark"] .clickable-id { color: var(--brand-gold); border-bottom-color: rgba(255,255,255,0.2);}
        .clickable-id:hover { opacity: 0.7; }

        .pagination .page-link { background: var(--input-bg); color: var(--text-main); border: 1px solid var(--border-glass); border-radius: 12px; margin: 0 4px; font-weight: 700; transition: 0.2s;}
        .pagination .active .page-link { background: var(--brand-primary); color: white; border-color: var(--brand-primary); }
        [data-theme="dark"] .pagination .active .page-link { background: var(--brand-gold); color: black; border-color: var(--brand-gold);}

        .timeline-box { position: relative; padding-right: 30px; border-right: 2px solid var(--border-glass); margin-top: 15px;}
        .timeline-item { position: relative; padding-bottom: 25px; text-align: right; }
        .timeline-item::after { content: ''; position: absolute; right: -36px; top: 5px; width: 10px; height: 10px; background: var(--brand-gold); border-radius: 50%; box-shadow: 0 0 0 4px var(--card-bg), 0 0 0 6px rgba(212, 175, 55, 0.2); }
        .data-line { display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border-glass); padding: 12px 0; font-size: 0.9rem; }
        .mobile-tx-card { display: none; }

        .tx-detail-modal .modal-dialog {
            max-width: min(1180px, calc(100vw - 32px));
        }
        .tx-detail-modal .modal-content {
            background: var(--card-bg);
            color: var(--text-main);
            border: 1px solid var(--border-glass) !important;
            border-radius: 18px;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.28);
            overflow: hidden;
        }
        .tx-detail-header {
            min-height: 86px;
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-glass);
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto auto auto;
            align-items: center;
            gap: 14px;
            background:
                linear-gradient(135deg, rgba(59, 130, 246, 0.10), rgba(16, 185, 129, 0.05)),
                var(--card-bg);
        }
        .tx-detail-title {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }
        .tx-detail-title-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(59, 130, 246, 0.12);
            color: #2563eb;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            font-size: 1.15rem;
        }
        .tx-detail-kicker {
            color: var(--text-muted);
            font-size: 0.72rem;
            font-weight: 900;
            margin-bottom: 3px;
        }
        .tx-detail-heading {
            font-size: 1.05rem;
            font-weight: 900;
            margin: 0;
            overflow-wrap: anywhere;
        }
        .tx-detail-ref {
            direction: ltr;
            text-align: left;
            font-family: 'JetBrains Mono', monospace;
            color: var(--brand-primary);
        }
        .tx-detail-close {
            position: static !important;
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background-color: var(--input-bg);
            opacity: 1;
            filter: none !important;
        }
        .tx-detail-print {
            border-radius: 10px;
            min-height: 38px;
            color: #111827 !important;
        }
        .tx-detail-header #m_header_status {
            justify-self: end;
        }
        .tx-detail-body {
            padding: 20px;
            background: rgba(148, 163, 184, 0.06);
        }
        [data-theme="dark"] .tx-detail-body {
            background: rgba(2, 6, 23, 0.18);
        }
        .tx-overview {
            display: grid;
            grid-template-columns: minmax(260px, 1.1fr) repeat(3, minmax(150px, 0.7fr));
            gap: 12px;
            margin-bottom: 16px;
        }
        .tx-overview-card,
        .tx-section,
        .tx-proof-panel {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 14px;
            box-shadow: var(--shadow-soft);
        }
        .tx-overview-card {
            padding: 14px;
            min-height: 96px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 8px;
        }
        .tx-overview-main {
            border-right: 4px solid var(--brand-primary);
        }
        .tx-label {
            color: var(--text-muted);
            display: block;
            font-size: 0.72rem;
            font-weight: 900;
            margin-bottom: 6px;
        }
        .tx-value {
            color: var(--text-main);
            display: block;
            font-size: 0.95rem;
            font-weight: 900;
            line-height: 1.45;
            overflow-wrap: anywhere;
        }
        .tx-value-lg {
            font-size: 1.15rem;
        }
        .tx-value-money {
            direction: ltr;
            text-align: right;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 0;
        }
        .tx-detail-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
            gap: 16px;
            align-items: start;
        }
        .tx-section {
            padding: 16px;
        }
        .tx-section + .tx-section {
            margin-top: 16px;
        }
        .tx-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding-bottom: 12px;
            margin-bottom: 12px;
            border-bottom: 1px solid var(--border-glass);
        }
        .tx-section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
            color: var(--text-main);
            font-size: 0.95rem;
            font-weight: 900;
        }
        .tx-section-title i {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(59, 130, 246, 0.10);
            color: #2563eb;
        }
        .tx-field-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }
        .tx-field {
            min-height: 78px;
            padding: 12px;
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            background: var(--input-bg);
        }
        .tx-field.wide {
            grid-column: 1 / -1;
        }
        .tx-note-box,
        .tx-account-box {
            white-space: pre-line;
            line-height: 1.75;
        }
        .tx-bot-control {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }
        .tx-bot-actions {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
            min-width: 0;
        }
        .tx-bot-actions .input-group {
            width: min(260px, 100%);
        }
        .tx-stage-list {
            display: grid;
            gap: 10px;
        }
        .tx-stage-item {
            display: grid;
            grid-template-columns: 40px minmax(0, 1fr);
            gap: 12px;
            padding: 12px;
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            background: var(--input-bg);
            position: relative;
        }
        .tx-stage-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(148, 163, 184, 0.16);
            color: var(--text-muted);
        }
        .tx-stage-name {
            color: var(--text-main);
            font-weight: 900;
            margin-bottom: 3px;
        }
        .tx-stage-meta {
            color: var(--text-muted);
            font-size: 0.78rem;
            font-weight: 800;
            direction: ltr;
            text-align: right;
        }
        .tx-stage-item.is-done .tx-stage-icon {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
        }
        .tx-stage-item.is-active .tx-stage-icon {
            background: rgba(245, 158, 11, 0.16);
            color: #d97706;
        }
        .tx-stage-item.is-failed .tx-stage-icon {
            background: rgba(239, 68, 68, 0.12);
            color: #ef4444;
        }
        .tx-proof-panel {
            padding: 14px;
        }
        .tx-proof-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }
        .tx-proof-title {
            display: flex;
            align-items: center;
            gap: 9px;
            margin: 0;
            font-size: 0.92rem;
            font-weight: 900;
        }
        .tx-proof-container {
            min-height: 300px;
            border: 1px dashed var(--border-glass);
            border-radius: 12px;
            background: rgba(15, 23, 42, 0.03);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        [data-theme="dark"] .tx-proof-container {
            background: rgba(2, 6, 23, 0.36);
        }
        .tx-proof-container img {
            display: block;
            width: auto;
            max-width: 100%;
            max-height: 560px;
            object-fit: contain;
        }

        @media (max-width: 991.98px) {
            .tx-detail-modal .modal-dialog {
                max-width: none;
                width: 100%;
                margin: 0;
                min-height: 100vh;
                align-items: stretch;
            }
            .tx-detail-modal .modal-content {
                min-height: 100vh;
                border-radius: 0;
            }
            .tx-detail-header {
                grid-template-columns: minmax(0, 1fr) auto;
                padding: 14px;
                gap: 10px;
                position: sticky;
                top: 0;
                z-index: 5;
            }
            .tx-detail-title-icon {
                width: 38px;
                height: 38px;
                border-radius: 10px;
            }
            .tx-detail-heading {
                font-size: 0.92rem;
            }
            .tx-detail-kicker {
                font-size: 0.68rem;
            }
            .tx-detail-print {
                grid-column: 1 / -1;
                width: 100%;
            }
            .tx-detail-header #m_header_status {
                grid-column: 1 / -1;
                justify-self: start;
            }
            .tx-detail-close {
                grid-column: 2;
                grid-row: 1;
            }
            .tx-detail-body {
                padding: 12px;
            }
            .tx-overview {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 10px;
            }
            .tx-overview-main {
                grid-column: 1 / -1;
            }
            .tx-detail-grid,
            .tx-field-grid {
                grid-template-columns: 1fr;
            }
            .tx-section {
                padding: 12px;
                border-radius: 12px;
            }
            .tx-field {
                min-height: 70px;
            }
            .tx-bot-control {
                align-items: stretch;
                flex-direction: column;
            }
            .tx-bot-actions {
                align-items: stretch;
            }
            .tx-bot-actions .input-group {
                width: 100%;
            }
            .tx-proof-container {
                min-height: 240px;
            }
            .tx-page-title {
                align-items: stretch !important;
                gap: 10px;
                flex-wrap: wrap;
            }
            .tx-page-title h3 {
                font-size: 1.05rem;
                line-height: 1.45;
                flex: 1 1 100%;
            }
            .tx-page-title .btn {
                flex: 1 1 auto;
                justify-content: center;
            }
            .summary-box {
                border-radius: 16px;
                padding: 14px;
            }
            .summary-val {
                font-size: 1rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .mobile-tx-card {
                display: block;
                background: var(--card-bg);
                border: 1px solid var(--border-glass);
                border-right: 4px solid var(--brand-primary);
                border-radius: 16px;
                padding: 14px;
                box-shadow: var(--shadow-soft);
            }
            .mobile-tx-card + .mobile-tx-card { margin-top: 12px; }
            .mobile-card-row {
                display: grid;
                grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                gap: 10px;
                align-items: center;
            }
            .mobile-card-row + .mobile-card-row {
                margin-top: 10px;
                padding-top: 10px;
                border-top: 1px dashed var(--border-glass);
            }
            .mobile-card-label {
                display: block;
                color: var(--text-muted);
                font-size: 0.72rem;
                font-weight: 800;
            }
            .mobile-card-value {
                display: block;
                color: var(--text-main);
                font-size: 0.88rem;
                font-weight: 900;
                overflow-wrap: anywhere;
            }
            .mobile-card-actions {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 8px;
            }
            .mobile-card-actions > *,
            .mobile-card-actions form,
            .mobile-card-actions .dropdown {
                min-width: 0;
                width: 100%;
                margin: 0;
            }
            .mobile-card-actions .btn,
            .mobile-card-actions button,
            .mobile-card-actions .btn-action-sm {
                width: 100%;
                min-height: 40px;
                height: 40px;
                border-radius: 10px;
                gap: 6px;
            }
            .mobile-card-actions .dropdown-menu {
                width: min(280px, calc(100vw - 36px));
                max-height: 60vh;
                overflow-y: auto;
            }
            .mobile-card-actions .dropdown-item {
                white-space: normal;
            }
        }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'transactions' }) %>

<div class="main-content">
    <div class="container-fluid">
        
        <div class="d-flex justify-content-between align-items-center mb-4 tx-page-title">
            <h3 class="fw-bold m-0" style="color: var(--text-main);"><i class="fa-solid fa-server text-primary me-2"></i> السجل المركزي والمراقبة <span class="spinner-grow spinner-grow-sm text-success ms-2 opacity-50" title="تحديث تلقائي"></span></h3>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="data-card summary-box box-success m-0">
                    <div>
                        <h6 class="fw-bold text-muted mb-2">إجمالي التحويلات (مكتملة)</h6>
                        <div class="summary-val text-success mb-1"><%= totals.transfersEGP.toFixed(2) %> <small class="fs-6">EGP</small></div>
                        <div class="text-danger fw-bold small mono-num"><%= totals.transfersLYD.toFixed(2) %> LYD</div>
                    </div>
                    <div class="summary-icon text-success"><i class="fa-solid fa-money-bill-transfer"></i></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="data-card summary-box box-primary m-0">
                    <div>
                        <h6 class="fw-bold text-muted mb-2">إجمالي الإيداعات (المسدد)</h6>
                        <div class="summary-val" style="color: #3b82f6;"><%= totals.depositsEGP.toFixed(2) %> <small class="fs-6">EGP</small></div>
                    </div>
                    <div class="summary-icon text-primary"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="data-card summary-box box-danger m-0">
                    <div>
                        <h6 class="fw-bold text-muted mb-2">مسحوب (خصومات)</h6>
                        <div class="summary-val text-danger"><%= totals.deductionsEGP.toFixed(2) %> <small class="fs-6">EGP</small></div>
                    </div>
                    <div class="summary-icon text-danger"><i class="fa-solid fa-arrow-trend-down"></i></div>
                </div>
            </div>
        </div>

        <div class="data-card border-0 mb-4 p-4">
            <form method="GET" action="/transactions" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">البحث الشامل</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" id="searchInput" name="search" class="form-control border-start-0 ps-0 mono-num fs-6" placeholder="الرقم، الحساب..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">حالة العملية</label>
                    <select id="statusFilter" name="status" class="form-select fw-bold">
                        <option value="">الجميع</option>
                        <option value="pending" <%= typeof statusFilter !== 'undefined' && statusFilter === 'pending' ? 'selected' : '' %>>⏳ معلق</option>
                        <option value="processing" <%= typeof statusFilter !== 'undefined' && statusFilter === 'processing' ? 'selected' : '' %>>⚙️ توجيه للمنفذ</option>
                        <option value="accepted" <%= typeof statusFilter !== 'undefined' && statusFilter === 'accepted' ? 'selected' : '' %>>👤 قيد العمل</option>
                        <option value="completed" <%= typeof statusFilter !== 'undefined' && statusFilter === 'completed' ? 'selected' : '' %>>✅ مكتمل</option>
                        <option value="deposit_pending" <%= typeof statusFilter !== 'undefined' && statusFilter === 'deposit_pending' ? 'selected' : '' %>>🖐️ طلب إيداع</option>
                        <option value="deposit" <%= typeof statusFilter !== 'undefined' && statusFilter === 'deposit' ? 'selected' : '' %>>💰 إيداع (سداد)</option>
                        <option value="deduction" <%= typeof statusFilter !== 'undefined' && statusFilter === 'deduction' ? 'selected' : '' %>>📉 خصم رصيد</option>
                        <option value="rejected" <%= typeof statusFilter !== 'undefined' && statusFilter === 'rejected' ? 'selected' : '' %>>❌ ملغي</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">من تاريخ</label>
                    <input type="date" id="fromDateInput" name="fromDate" class="form-control fw-bold" value="<%= typeof fromDate !== 'undefined' ? fromDate : '' %>">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">إلى تاريخ</label>
                    <input type="date" id="toDateInput" name="toDate" class="form-control fw-bold" value="<%= typeof toDate !== 'undefined' ? toDate : '' %>">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary fw-bold px-4 flex-fill"><i class="fa-solid fa-filter me-1"></i> عرض</button>
                    <a href="/transactions" class="btn btn-light fw-bold"><i class="fa-solid fa-rotate-left"></i></a>
                    <button type="button" class="btn fw-bold" style="background: var(--brand-gold); color: #000;" onclick="printReport()"><i class="fa-solid fa-print"></i></button>
                </div>
            </form>
        </div>

        <div class="data-card border-0 p-0 overflow-hidden">
            <div class="table-responsive border-0 m-0 d-none d-lg-block">
                <table class="table text-center align-middle m-0" id="transactionsTable">
                    <thead class="table-light">
                        <tr>
                            <th>رقم العملية</th>
                            <th>الجهة/العميل</th>
                            <th>المبلغ ج.م</th>
                            <th>الرقم/الحساب</th>
                            <th>التكلفة/سعر الصرف</th>
                            <th>بوت التنفيذ</th>
                            <th>الملاحظة</th>
                            <th>الحالة</th>
                            <th>الإثبات</th>
                            <th>اجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transactions.length === 0) { %>
                            <tr><td colspan="10" class="py-5 text-muted fw-bold border-0 fs-5"><i class="fa-solid fa-folder-open fs-1 d-block mb-3 opacity-25"></i> لا توجد عمليات مطابقة.</td></tr>
                        <% } %>
                        <% transactions.forEach(tx => { const txProofCount = tx.proofImages && tx.proofImages.length > 0 ? tx.proofImages.length : (tx.proofImage ? 1 : 0); %>
                            <tr style="<%= tx.status === 'deposit_pending' ? 'background: rgba(245, 158, 11, 0.05);' : (tx.status === 'deposit' ? 'background: rgba(16, 185, 129, 0.05);' : (tx.status === 'deduction' ? 'background: rgba(239, 68, 68, 0.05);' : '')) %>">
                            
                            <td>
                                <a class="clickable-id mono-num fs-6" data-tx='<%- JSON.stringify(tx).replace(/'/g, "&#39;") %>' onclick="viewTransactionDetails(this)">
                                    #<%= tx.customId || tx._id.toString().slice(-6) %>
                                </a>
                            </td>

                            <td class="fw-bold text-dark">
                                <% if (tx.companyName && tx.companyName !== 'عميل فردي') { %>
                                    <div title="الطالب: <%= tx.employeeName %>"><i class="fa-solid fa-building text-muted me-1 small"></i> <%= tx.companyName %></div>
                                    <div class="text-muted small mt-1"><i class="fa-solid fa-user-pen opacity-50 me-1"></i> <%= tx.employeeName %></div>
                                <% } else { %>
                                    <div><i class="fa-solid fa-user text-muted me-1 small"></i> <%= tx.employeeName || 'غير معروف' %></div>
                                <% } %>
                            </td>

                            <td class="text-<%= tx.status === 'deduction' ? 'danger' : 'success' %> fw-bold mono-num fs-5"><%= tx.amount.toFixed(2) %></td>

                            <td>
                                <div class="mono-num text-dark fw-bold fs-6" dir="ltr"><%= tx.vodafoneNumber || tx.accountNumber || '---' %></div>
                                <div class="mt-1">
                                    <% let numStr = tx.vodafoneNumber || tx.accountNumber || ''; %>
                                    <% if(tx.transferType === 'post_account') { %> <span class="badge bg-warning text-dark opacity-75"><i class="fa-solid fa-envelope"></i> بريد</span>
                                    <% } else if(tx.transferType === 'post_card') { %> <span class="badge bg-info text-dark opacity-75"><i class="fa-solid fa-id-card"></i> بطاقة</span>
                                    <% } else if(tx.status === 'deposit' || tx.status === 'deduction') { %> <span class="badge bg-secondary opacity-75"><i class="fa-solid fa-money-bill-wave"></i> تسوية</span>
                                    <% } else { %> 
                                        <div class="fw-bold small mt-1">
                                            <% if(numStr.startsWith('010')) { %> <span style="color: #dc3545;">فودافون</span>
                                            <% } else if(numStr.startsWith('011')) { %> <span style="color: #198754;">اتصالات</span>
                                            <% } else if(numStr.startsWith('012')) { %> <span style="color: #fd7e14;">اورانج</span>
                                            <% } else if(numStr.startsWith('015')) { %> <span style="color: #0dcaf0;">وي</span>
                                            <% } else { %> <span class="badge bg-danger opacity-75"><i class="fa-solid fa-mobile-screen"></i> كاش</span> <% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </td>

                            <td>
                                <% if(tx.status === 'deposit' || tx.status === 'deduction') { %> 
                                    <span class="text-muted">---</span>
                                <% } else { %> 
                                    <div class="text-danger fw-bold mono-num fs-6"><%= tx.costLYD ? tx.costLYD.toFixed(2) + ' LYD' : '---' %></div>
                                    <div class="text-warning fw-bold mono-num small mt-1" style="color: var(--brand-gold) !important;" title="سعر الصرف"><i class="fa-solid fa-percent opacity-50 me-1"></i><%= tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (tx.amount / tx.costLYD).toFixed(2) : '---') %></div>
                                <% } %>
                            </td>

                            <td>
                                <% if(tx.status === 'deposit' || tx.status === 'deduction') { %> 
                                    <span class="text-muted">---</span>
                                <% } else { %>
                                    <div class="fw-bold text-primary small"><i class="fa-solid fa-robot me-1 opacity-50"></i> <%= typeof allBotsMap !== 'undefined' && tx.executorBotId ? allBotsMap[tx.executorBotId] : (tx.executorBotName || 'غير محدد') %></div>
                                    <div class="text-muted small mt-1"><i class="fa-solid fa-user-gear me-1 opacity-50"></i> <%= tx.executorName || 'غير محدد' %></div>
                                <% } %>
                            </td>

                            <td class="small text-wrap" style="max-width: 150px; line-height: 1.4;">
                                <div class="fw-bold text-dark mb-1">
                                    <% 
                                        let displayNote = tx.notes || '---';
                                        if (displayNote.includes('--- سجل الـ API')) {
                                            displayNote = displayNote.split('--- سجل الـ API')[0].trim();
                                        }
                                    %>
                                    <%= displayNote %>
                                </div>
                                <div class="text-muted mono-num" style="font-size: 0.75rem;">
                                    <i class="fa-regular fa-clock me-1"></i> <%= tx.createdAt.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %><br>
                                    <span class="opacity-75"><%= tx.createdAt.toLocaleDateString('en-GB') %></span>
                                </div>
                            </td>

                            <td>
                                <% if(tx.status === 'completed') { %> <span class="badge-st st-done"><i class="fa-solid fa-check"></i> مكتمل</span>
                                <% } else if(tx.status === 'pending') { %> <span class="badge-st st-wait"><i class="fa-solid fa-pause"></i> معلق</span>
                                <% } else if(tx.status === 'processing') { %> <span class="badge-st st-proc"><i class="fa-solid fa-spinner fa-spin"></i> توجيه</span>
                                <% } else if(tx.status === 'accepted') { %> <span class="badge-st st-work"><i class="fa-solid fa-user-gear"></i> قيد العمل</span>
                                <% } else if(tx.status === 'deposit_pending') { %> <span class="badge-st st-wait"><i class="fa-solid fa-hand"></i> طلب إيداع</span>
                                <% } else if(tx.status === 'deposit') { %> <span class="badge-st st-done"><i class="fa-solid fa-arrow-down"></i> إيداع</span>
                                <% } else if(tx.status === 'deduction') { %> <span class="badge-st" style="background: rgba(108,117,125,0.1); color:#6c757d;"><i class="fa-solid fa-arrow-up"></i> خصم</span>
                                <% } else { %> <span class="badge-st st-fail"><i class="fa-solid fa-ban"></i> ملغي</span> <% } %>
                            </td>

                            <td>
                                <% if (txProofCount > 0) { %>
                                    <button type="button" class="proof-thumb-btn" data-tx='<%- JSON.stringify(tx).replace(/'/g, "&#39;") %>' onclick="viewTransactionDetails(this)" title="عرض صور الإثبات">
                                        <span class="proof-thumb-frame">
                                            <img class="proof-thumb-img" src="/proxy/image/<%= tx._id %>/0" loading="lazy" alt="إثبات العملية <%= tx.customId || tx._id.toString().slice(-6) %>" onerror="handleProofThumbError(this)">
                                            <span class="proof-thumb-fallback"><i class="fa-solid fa-image"></i></span>
                                            <% if (txProofCount > 1) { %><span class="proof-thumb-count"><%= txProofCount %></span><% } %>
                                        </span>
                                        <span class="proof-thumb-label">عرض الإثبات</span>
                                    </button>
                                <% } else { %>
                                    <span class="proof-empty"><i class="fa-regular fa-image"></i> لا يوجد</span>
                                <% } %>
                            </td>

                            <td>
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <% if (tx.status === 'deposit_pending') { %>
                                        <button class="btn btn-sm btn-success fw-bold rounded-3" onclick="showAcceptDepositModal('<%= tx._id %>')"><i class="fa-solid fa-check"></i> قبول</button>
                                        <form action="/transaction/<%= tx._id %>/reject-deposit-web" method="POST" class="m-0" onsubmit="return promptRejectDeposit(this)">
                                            <input type="hidden" name="reason" class="reject-reason-input">
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold rounded-3"><i class="fa-solid fa-xmark"></i> رفض</button>
                                        </form>
                                    <% } else { %>
                                        
                                        <% if(tx.status === 'pending') { %>
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-primary fw-bold rounded-3 dropdown-toggle" type="button" data-bs-toggle="dropdown">توجيه</button>
                                                <ul class="dropdown-menu border-0 shadow-lg" style="border-radius: 12px; min-width: 180px;">
                                                    <li class="px-3 py-2 text-muted small fw-bold border-bottom mb-1">اختر البوت:</li>
                                                    <% if(typeof executorBots !== 'undefined' && executorBots.length > 0) { %>
                                                        <% executorBots.forEach(bot => { %>
                                                            <li>
                                                                <form action="/transaction/<%= tx._id %>/assign-executor" method="POST" class="m-0 p-0">
                                                                    <input type="hidden" name="executorBotId" value="<%= bot._id %>">
                                                                    <button type="submit" class="dropdown-item py-2 fw-bold text-dark d-flex align-items-center"><i class="fa-solid fa-robot text-primary me-2"></i> <%= bot.name %></button>
                                                                </form>
                                                            </li>
                                                        <% }) %>
                                                    <% } %>
                                                </ul>
                                            </div>
                                        <% } else if(tx.status === 'processing' || tx.status === 'accepted') { %>
                                            <form action="/transaction/<%= tx._id %>/pull-task" method="POST" class="mb-0" onsubmit="return confirm('تأكيد سحب المهمة؟')">
                                                <button class="btn btn-sm btn-warning fw-bold rounded-3 text-dark px-3" title="سحب للإدارة">سحب</button>
                                            </form>
                                            <form action="/transaction/<%= tx._id %>/emergency-alert" method="POST" class="mb-0" onsubmit="return confirmEmergencyAlert(this);">
                                                <input type="hidden" name="alertMessage" class="alert-message-input">
                                                <button type="submit" class="btn btn-sm btn-danger fw-bold rounded-3 px-3 ms-1" title="إطلاق إنذار أحمر">إنذار</button>
                                            </form>
                                        <% } %>
                                        
                                        <% if(['pending', 'processing', 'accepted', 'completed', 'deposit', 'deduction', 'rejected'].includes(tx.status)) { %>
                                             
                                            <% if (tx.notes && tx.notes.includes('--- سجل الـ API')) { %>
                                                <button class="btn-action-sm api-log" data-log="<%= encodeURIComponent(tx.notes) %>" onclick="showApiLog(this)" title="سجل Terminal للـ API"><i class="fa-solid fa-terminal"></i></button>
                                            <% } %>

                                            <% if (tx.status === 'completed' && (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0))) { %>
                                                <form action="/transaction/<%= tx._id %>/resend-proof" method="POST" class="m-0" onsubmit="return confirm('إعادة إرسال الإيصال للعميل؟')">
                                                    <button type="submit" class="btn-action-sm send" title="إعادة الإرسال"><i class="fa-solid fa-paper-plane"></i></button>
                                                </form>
                                            <% } %>
                                            <button class="btn-action-sm edit" onclick="openEditTxModal('<%= tx._id %>', '<%= tx.amount %>', '<%= tx.createdAt.toISOString() %>')" title="تعديل"><i class="fa-solid fa-pen"></i></button>
                                            <% if(tx.status !== 'deposit' && tx.status !== 'deduction') { %>
                                                <button class="btn-action-sm edit" onclick="openEditRateModal('<%= tx._id %>', '<%= tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (tx.amount / tx.costLYD).toFixed(2) : 0) %>')" title="تعديل الصرف"><i class="fa-solid fa-percent"></i></button>
                                            <% } %>
                                        <% } %>

                                        <form action="/transaction/<%= tx._id %>/global-cancel" method="POST" class="m-0" onsubmit="return confirm('تأكيد التراجع عن العملية وإرجاع الأرصدة؟')">
                                            <button class="btn-action-sm undo" title="تراجع"><i class="fa-solid fa-rotate-left"></i></button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <div class="d-lg-none p-3" id="mobileCardsContainer">
                <% if (transactions.length === 0) { %>
                    <div class="text-center py-5 text-muted fw-bold border-0 fs-5">
                        <i class="fa-solid fa-folder-open fs-1 d-block mb-3 opacity-25"></i>
                        لا توجد عمليات مطابقة.
                    </div>
                <% } %>
                <% transactions.forEach(tx => { const txProofCount = tx.proofImages && tx.proofImages.length > 0 ? tx.proofImages.length : (tx.proofImage ? 1 : 0); %>
                    <div class="mobile-tx-card">
                        <div class="mobile-card-row">
                            <div>
                                <span class="mobile-card-label">رقم العملية</span>
                                <a class="clickable-id mono-num mobile-card-value" data-tx='<%- JSON.stringify(tx).replace(/'/g, "&#39;") %>' onclick="viewTransactionDetails(this)">
                                    #<%= tx.customId || tx._id.toString().slice(-6) %>
                                </a>
                            </div>
                            <div class="text-end">
                                <% if(tx.status === 'completed') { %> <span class="badge-st st-done"><i class="fa-solid fa-check"></i> مكتمل</span>
                                <% } else if(tx.status === 'pending') { %> <span class="badge-st st-wait"><i class="fa-solid fa-pause"></i> معلق</span>
                                <% } else if(tx.status === 'processing') { %> <span class="badge-st st-proc"><i class="fa-solid fa-spinner fa-spin"></i> توجيه</span>
                                <% } else if(tx.status === 'accepted') { %> <span class="badge-st st-work"><i class="fa-solid fa-user-gear"></i> قيد العمل</span>
                                <% } else if(tx.status === 'deposit_pending') { %> <span class="badge-st st-wait"><i class="fa-solid fa-hand"></i> طلب إيداع</span>
                                <% } else if(tx.status === 'deposit') { %> <span class="badge-st st-done"><i class="fa-solid fa-arrow-down"></i> إيداع</span>
                                <% } else if(tx.status === 'deduction') { %> <span class="badge-st" style="background: rgba(108,117,125,0.1); color:#6c757d;"><i class="fa-solid fa-arrow-up"></i> خصم</span>
                                <% } else { %> <span class="badge-st st-fail"><i class="fa-solid fa-ban"></i> ملغي</span> <% } %>
                            </div>
                        </div>
                        <div class="mobile-card-row">
                            <div>
                                <span class="mobile-card-label">الجهة</span>
                                <span class="mobile-card-value"><%= tx.companyName || tx.employeeName || 'عميل فردي' %></span>
                            </div>
                            <div>
                                <span class="mobile-card-label">الموظف</span>
                                <span class="mobile-card-value"><%= tx.employeeName || '---' %></span>
                            </div>
                        </div>
                        <div class="mobile-card-row">
                            <div>
                                <span class="mobile-card-label">المبلغ</span>
                                <span class="mobile-card-value mono-num <%= tx.status === 'deduction' ? 'text-danger' : 'text-success' %>"><%= tx.amount.toFixed(2) %> EGP</span>
                            </div>
                            <div>
                                <span class="mobile-card-label">التكلفة</span>
                                <span class="mobile-card-value mono-num text-danger"><%= tx.costLYD ? tx.costLYD.toFixed(2) : '---' %> LYD</span>
                            </div>
                        </div>
                        <div class="mobile-card-row">
                            <div>
                                <span class="mobile-card-label">الرقم/الحساب</span>
                                <span class="mobile-card-value mono-num" dir="ltr"><%= tx.vodafoneNumber || tx.accountNumber || '---' %></span>
                            </div>
                            <div>
                                <span class="mobile-card-label">التاريخ</span>
                                <span class="mobile-card-value mono-num" dir="ltr"><%= tx.createdAt.toLocaleDateString('en-GB') %> <%= tx.createdAt.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %></span>
                            </div>
                        </div>
                        <% if (txProofCount > 0) { %>
                            <div class="mobile-card-row" style="grid-template-columns: 1fr;">
                                <button type="button" class="proof-mobile-btn" data-tx='<%- JSON.stringify(tx).replace(/'/g, "&#39;") %>' onclick="viewTransactionDetails(this)">
                                    <span class="proof-thumb-frame">
                                        <img class="proof-thumb-img" src="/proxy/image/<%= tx._id %>/0" loading="lazy" alt="إثبات العملية <%= tx.customId || tx._id.toString().slice(-6) %>" onerror="handleProofThumbError(this)">
                                        <span class="proof-thumb-fallback"><i class="fa-solid fa-image"></i></span>
                                        <% if (txProofCount > 1) { %><span class="proof-thumb-count"><%= txProofCount %></span><% } %>
                                    </span>
                                    <span>
                                        <span class="proof-mobile-title">صور الإثبات</span>
                                        <span class="proof-mobile-subtitle">اضغط لعرض الإيصال بحجم كامل</span>
                                    </span>
                                </button>
                            </div>
                        <% } %>
                        <div class="mobile-card-row" style="grid-template-columns: 1fr;">
                            <div class="mobile-card-actions">
                                <% if (tx.status === 'deposit_pending') { %>
                                    <button class="btn btn-sm btn-success fw-bold" onclick="showAcceptDepositModal('<%= tx._id %>')">
                                        <i class="fa-solid fa-check me-1"></i> قبول الإيداع
                                    </button>
                                    <form action="/transaction/<%= tx._id %>/reject-deposit-web" method="POST" onsubmit="return promptRejectDeposit(this)">
                                        <input type="hidden" name="reason" class="reject-reason-input">
                                        <button type="submit" class="btn btn-sm btn-danger fw-bold">
                                            <i class="fa-solid fa-xmark me-1"></i> رفض الإيداع
                                        </button>
                                    </form>
                                <% } else { %>
                                    <% if(tx.status === 'pending') { %>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-primary fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                <i class="fa-solid fa-route me-1"></i> توجيه
                                            </button>
                                            <ul class="dropdown-menu border-0 shadow-lg" style="border-radius: 12px;">
                                                <li class="px-3 py-2 text-muted small fw-bold border-bottom mb-1">اختر المنفذ:</li>
                                                <% if(typeof executorBots !== 'undefined' && executorBots.length > 0) { %>
                                                    <% executorBots.forEach(bot => { %>
                                                        <li>
                                                            <form action="/transaction/<%= tx._id %>/assign-executor" method="POST">
                                                                <input type="hidden" name="executorBotId" value="<%= bot._id %>">
                                                                <button type="submit" class="dropdown-item py-2 fw-bold d-flex align-items-center">
                                                                    <i class="fa-solid <%= bot.isApiBot ? 'fa-code' : 'fa-robot' %> text-primary me-2"></i>
                                                                    <span><%= bot.name %></span>
                                                                </button>
                                                            </form>
                                                        </li>
                                                    <% }) %>
                                                <% } else { %>
                                                    <li><span class="dropdown-item text-muted">لا توجد بوتات متاحة</span></li>
                                                <% } %>
                                            </ul>
                                        </div>
                                    <% } %>

                                    <% if(tx.status === 'processing' || tx.status === 'accepted') { %>
                                        <form action="/transaction/<%= tx._id %>/pull-task" method="POST" onsubmit="return confirm('تأكيد سحب المهمة؟')">
                                            <button type="submit" class="btn btn-sm btn-warning fw-bold text-dark">
                                                <i class="fa-solid fa-hand-back-fist me-1"></i> سحب
                                            </button>
                                        </form>
                                        <form action="/transaction/<%= tx._id %>/emergency-alert" method="POST" onsubmit="return confirmEmergencyAlert(this);">
                                            <input type="hidden" name="alertMessage" class="alert-message-input">
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold">
                                                <i class="fa-solid fa-triangle-exclamation me-1"></i> إنذار
                                            </button>
                                        </form>
                                    <% } %>
                                <% } %>

                                <button type="button" class="btn btn-sm btn-primary fw-bold" data-tx='<%- JSON.stringify(tx).replace(/'/g, "&#39;") %>' onclick="viewTransactionDetails(this)">
                                    <i class="fa-solid fa-eye me-1"></i> التفاصيل
                                </button>
                                <% if (tx.notes && tx.notes.includes('--- سجل الـ API')) { %>
                                    <button type="button" class="btn-action-sm api-log" data-log="<%= encodeURIComponent(tx.notes) %>" onclick="showApiLog(this)" title="سجل Terminal للـ API">
                                        <i class="fa-solid fa-terminal"></i>
                                    </button>
                                <% } %>
                                <% if (tx.status === 'completed' && (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0))) { %>
                                    <form action="/transaction/<%= tx._id %>/resend-proof" method="POST" onsubmit="return confirm('إعادة إرسال الإيصال للعميل؟')">
                                        <button type="submit" class="btn-action-sm send" title="إعادة الإرسال">
                                            <i class="fa-solid fa-paper-plane"></i>
                                        </button>
                                    </form>
                                <% } %>
                                <button type="button" class="btn btn-sm btn-light fw-bold" onclick="openEditTxModal('<%= tx._id %>', '<%= tx.amount %>', '<%= tx.createdAt.toISOString() %>')">
                                    <i class="fa-solid fa-pen me-1"></i> تعديل
                                </button>
                                <% if(tx.status !== 'deposit' && tx.status !== 'deduction') { %>
                                    <button type="button" class="btn-action-sm edit" onclick="openEditRateModal('<%= tx._id %>', '<%= tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (tx.amount / tx.costLYD).toFixed(2) : 0) %>')" title="تعديل الصرف">
                                        <i class="fa-solid fa-percent"></i>
                                    </button>
                                <% } %>
                                <% if (tx.status !== 'deposit_pending') { %>
                                    <form action="/transaction/<%= tx._id %>/global-cancel" method="POST" onsubmit="return confirm('تأكيد التراجع عن العملية وإرجاع الأرصدة؟')">
                                        <button type="submit" class="btn-action-sm undo" title="تراجع">
                                            <i class="fa-solid fa-rotate-left"></i>
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <nav class="mt-4 pt-3 pb-3">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link shadow-sm" href="?page=<%= currentPage - 1 %>&search=<%= search %>&status=<%= statusFilter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>"><i class="fa-solid fa-angle-right"></i></a>
                        </li>
                        <% let startPage = Math.max(1, currentPage - 2); let endPage = Math.min(totalPages, currentPage + 2); for(let i = startPage; i <= endPage; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link shadow-sm" href="?page=<%= i %>&search=<%= search %>&status=<%= statusFilter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link shadow-sm" href="?page=<%= currentPage + 1 %>&search=<%= search %>&status=<%= statusFilter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>"><i class="fa-solid fa-angle-left"></i></a>
                        </li>
                    </ul>
                </nav>
            <% } %>

        </div>
    </div>
</div>

